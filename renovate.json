{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":disableRateLimiting",
    ":automergeMinor",
    ":automergeBranch"
  ],
  "packageRules": [
    {
      "matchFileNames": [
        "infrastructure/networking/gateway-api-crds/app/repo.yaml"
      ],
      "matchUpdateTypes": [
        "minor"
      ],
      "automerge": false
    }
  ],
  "dependencyDashboardTitle": "Renovate Dashboard 🤖",
  "commitMessageExtra": "from {{{displayFrom}}} to {{{displayTo}}}",
  "ignoreTests": true,
  "flux": {
    "managerFilePatterns": [
      "/\\.yaml$/"
    ]
  },
  "helm-values": {
    "managerFilePatterns": [
      "/\\.yaml(?:\\.j2)?$/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/\\.yaml(?:\\.j2)?$/"
    ]
  }
}
